# Copia este archivo a .env.local y rellena los valores reales.
# .env.local está en .gitignore y NUNCA debe subirse al repo.

# ── Supabase ────────────────────────────────────────────────────────────────
# Settings → API en tu proyecto de Supabase
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# ── Gemini (Google AI Studio) ───────────────────────────────────────────────
# https://aistudio.google.com  → Get API key
GEMINI_API_KEY=tu-gemini-api-key

# Opcionales — modelos por defecto si no se definen:
# GEMINI_MODEL=gemini-2.5-flash            # texto (plan, recetas, conteo por foto)
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image # imagen (foto IA del plato; requiere billing)
